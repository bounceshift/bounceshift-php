{
    "name": "bounceshift/bounceshift-php",
    "description": "Framework-agnostic PHP SDK for the BounceShift email-validation API.",
    "keywords": [
        "bounceshift",
        "email",
        "email-validation",
        "email-verification",
        "deliverability",
        "sdk"
    ],
    "homepage": "https://bounceshift.com",
    "license": "MIT",
    "version": "1.2.0",
    "type": "library",
    "authors": [
        {
            "name": "BounceShift",
            "homepage": "https://bounceshift.com"
        }
    ],
    "support": {
        "docs": "https://bounceshift.com/docs/api",
        "issues": "https://github.com/bounceshift/bounceshift-php/issues",
        "source": "https://github.com/bounceshift/bounceshift-php"
    },
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "php-http/discovery": "^1.19",
        "guzzlehttp/guzzle": "^7.8"
    },
    "require-dev": {
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "BounceShift\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BounceShift\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
